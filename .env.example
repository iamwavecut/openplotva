# OpenPlotva environment template.
# Copy to .env and uncomment only the values you want to override.
# Do not commit filled secrets, live Telegram IDs, database dumps, or provider keys.

# -----------------------------------------------------------------------------
# HTTP and runtime API
# -----------------------------------------------------------------------------
# OPENPLOTVA_BIND_ADDR=0.0.0.0:8080
# WEBAPP_HOST=0.0.0.0
# WEBAPP_PORT=8080
# WEBAPP_URL=http://127.0.0.1:8080
# OPENPLOTVA_LOG_FILTER=openplotva=info,tower_http=info
# LOG_LEVEL=info
# RUNTIME_API_ENABLED=false
# RUNTIME_API_HOST=127.0.0.1
# RUNTIME_API_PORT=9091
# RUNTIME_API_LOG_BUFFER_SIZE=200
# RUNTIME_API_SQL_TIMEOUT_MS=10000
# RUNTIME_API_SQL_ROW_LIMIT=200
# RUNTIME_API_SQL_RESULT_BYTES_LIMIT=2621440
# Required only when RUNTIME_API_ENABLED=true.
# RUNTIME_API_CERT_FILE=
# RUNTIME_API_KEY_FILE=
# RUNTIME_API_TLS_PUBLIC_KEY_PIN=

# -----------------------------------------------------------------------------
# Postgres and Redis/Dragonfly
# -----------------------------------------------------------------------------
# DB_POSTGRES_HOST=127.0.0.1
# DB_POSTGRES_PORT=5432
# DB_POSTGRES_USER=plotva
# DB_POSTGRES_PASSWORD=plotva
# DB_POSTGRES_DB=plotva
# DB_POSTGRES_SSL_MODE=disable
# REDIS_HOST=127.0.0.1
# REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_DB=0

# -----------------------------------------------------------------------------
# Telegram bot and admin access
# -----------------------------------------------------------------------------
# Required to connect a real bot.
# BOT_KEY=
# BOT_API_BASE_URL=
# BOT_DEBUG=false
# BOT_WEBHOOK_ENABLED=false
# BOT_WEBHOOK_URL=
# BOT_WEBHOOK_CERT_FILE=
# BOT_WEBHOOK_KEY_FILE=
# BOT_WEBHOOK_SECRET_TOKEN=
# Comma-separated Telegram user IDs allowed to use admin commands.
# ADMINS_ADMIN_IDS=

# -----------------------------------------------------------------------------
# Runtime service switches
# -----------------------------------------------------------------------------
# OPENPLOTVA_CONNECT_SERVICES=false
# OPENPLOTVA_RUN_MIGRATIONS=false
# OPENPLOTVA_PRODUCE_UPDATES=true
# OPENPLOTVA_CONSUME_UPDATES=true

# -----------------------------------------------------------------------------
# Persistent queues and workers
# -----------------------------------------------------------------------------
# PERSISTENT_QUEUE_ENABLED=true
# PERSISTENT_QUEUE_HEARTBEAT_INTERVAL_SECONDS=30
# PERSISTENT_QUEUE_RECOVERY_INTERVAL_SECONDS=60
# PERSISTENT_QUEUE_CLEANUP_INTERVAL_SECONDS=300
# PERSISTENT_QUEUE_DEFAULT_PROCESSING_TIMEOUT_SECONDS=300
# PERSISTENT_QUEUE_MAX_RETRIES=3
# PERSISTENT_QUEUE_COMPLETED_JOB_RETENTION_DAYS=1
# PERSISTENT_QUEUE_MESSAGE_CLEANUP_INTERVAL_SECONDS=300
# PERSISTENT_QUEUE_JOB_MESSAGE_CLEANUP_MINUTES=30
# PERSISTENT_QUEUE_CONTROL_WORKERS=2
# PERSISTENT_QUEUE_TEXT_WORKERS=4
# PERSISTENT_QUEUE_DIALOG_AIFARM_WORKERS=2
# PERSISTENT_QUEUE_DIALOG_AIFARM_FALLBACK_WORKERS=1
# PERSISTENT_QUEUE_DIALOG_AIFARM_FALLBACK_HIGH_WATERMARK=30
# PERSISTENT_QUEUE_DIALOG_AIFARM_FALLBACK_LOW_WATERMARK=20
# PERSISTENT_QUEUE_DIALOG_AIFARM_FALLBACK_POLL_INTERVAL_SECONDS=1
# PERSISTENT_QUEUE_IMAGE_REGULAR_WORKERS=1
# PERSISTENT_QUEUE_IMAGE_VIP_WORKERS=1
# PERSISTENT_QUEUE_MUSIC_VIP_WORKERS=1
# PERSISTENT_QUEUE_MEMORY_CONSOLIDATION_WORKERS=1
# PERSISTENT_QUEUE_PLACEHOLDER_CLEANUP_INTERVAL_SECONDS=3600
# PERSISTENT_QUEUE_PLACEHOLDER_MAX_AGE_SECONDS=7200
# PERSISTENT_QUEUE_SNAPSHOT_PATH=
# PERSISTENT_QUEUE_SNAPSHOT_INTERVAL_SECONDS=60
# LLM_JOB_MAX_ATTEMPTS=5

# -----------------------------------------------------------------------------
# Search, translation, and browser fetch providers
# -----------------------------------------------------------------------------
# RBC_TIMEOUT_SECONDS=15
# SERPER_API_KEY=
# SERPER_TIMEOUT_SECONDS=30
# DEEPL_KEY=
# DEEPL_URL=

# -----------------------------------------------------------------------------
# LLM providers and routing
# -----------------------------------------------------------------------------
# GOOGLEAI_KEY=
# GOOGLEAI_KEY_STATS_FILE=
# OPENROUTER_KEY=
# OPENROUTER_REQUEST_TIMEOUT_SECONDS=300
# WHITECIRCLE_ENABLED=false
# WHITECIRCLE_API_KEY=
# WHITECIRCLE_DEPLOYMENT_ID=
# DISCOVERY_BASE_URL=http://127.0.0.1:50051
# GENKIT_DEFAULT_MODEL=
# GENKIT_HISTORY_SUMMARY_PROVIDER=aifarm
# GENKIT_HISTORY_SUMMARY_MODEL=
# GENKIT_HISTORY_SUMMARY_TIMEOUT_SECONDS=600

# -----------------------------------------------------------------------------
# Dialog provider tuning
# -----------------------------------------------------------------------------
# DIALOG_PROVIDER=aifarm
# DIALOG_FALLBACK_PROVIDER=genkit
# DIALOG_MODEL=Gemma 4 26B Heretic
# DIALOG_URL=
# DIALOG_API_KEY=
# DIALOG_DISCOVERY_SERVICE_NAME=llm-openai
# DIALOG_DISCOVERY_ENDPOINT_NAME=chat_completions
# DIALOG_AIFARM_ENABLE_THINKING=false
# DIALOG_AIFARM_USE_TOOL_CALLS=true
# DIALOG_AIFARM_MAX_TOKENS=1024
# DIALOG_AIFARM_RANDOM_MAX_TOKENS=768
# DIALOG_AIFARM_DEFAULT_MAX_TOKENS=4096
# DIALOG_AIFARM_LONG_MAX_TOKENS=4096
# DIALOG_AIFARM_TEMPERATURE=0.2
# DIALOG_AIFARM_REPEAT_PENALTY=1.1
# DIALOG_AIFARM_FREQUENCY_PENALTY=0
# DIALOG_AIFARM_PRESENCE_PENALTY=0
# DIALOG_AIFARM_DRY_MULTIPLIER=0
# DIALOG_AIFARM_DRY_BASE=1.75
# DIALOG_AIFARM_DRY_ALLOWED_LENGTH=2
# DIALOG_REQUEST_TIMEOUT_SECONDS=30
# DIALOG_POLL_INTERVAL_SECONDS=1
# DIALOG_TASK_TIMEOUT_SECONDS=720
# DIALOG_AIFARM_CAPACITY_WAIT_SECONDS=60
# DIALOG_AIFARM_CAPACITY_POLL_SECONDS=1
# DIALOG_AIFARM_POOL_MODELS=
# DIALOG_AIFARM_POOL_BASE_URLS=
# DIALOG_AIFARM_POOL_API_KEY=
# DIALOG_AIFARM_POOL_PRIMARY_CAPACITY_WAIT_MS=500
# DIALOG_AIFARM_POOL_REASONING_MAX_TOKENS=8192
# DIALOG_VMLX_URL=
# DIALOG_VMLX_API_KEY=
# DIALOG_VMLX_MODEL=default
# DIALOG_NVIDIA_URL=https://integrate.api.nvidia.com/v1/chat/completions
# DIALOG_NVIDIA_API_KEY=
# DIALOG_NVIDIA_MODEL=google/gemma-4-31b-it
# DIALOG_NVIDIA_MAX_TOKENS=16384
# DIALOG_NVIDIA_TEMPERATURE=1
# DIALOG_NVIDIA_TOP_P=0.95
# DIALOG_NVIDIA_ENABLE_THINKING=true
# DIALOG_NVIDIA_INCLUDE_REASONING=false

# -----------------------------------------------------------------------------
# Image and music providers
# -----------------------------------------------------------------------------
# PRUNA_ENDPOINT=
# PRUNA_MODEL=prunaai/p-image
# PRUNA_API_KEY=
# PRUNA_BEARER=
# PRUNA_TIMEOUT_SECONDS=120
# ACESTEP_ENABLED=false
# ACESTEP_BASE_URL=http://127.0.0.1:8001
# ACESTEP_API_KEY=
# ACESTEP_API_MODE=completion
# ACESTEP_REQUEST_TIMEOUT_SECONDS=90
# ACESTEP_POLL_INTERVAL_SECONDS=2
# ACESTEP_TASK_TIMEOUT_SECONDS=600
# ACESTEP_AUDIO_FORMAT=mp3
# ACESTEP_MODEL=acemusic/acestep-v1.5-turbo

# -----------------------------------------------------------------------------
# Vision
# -----------------------------------------------------------------------------
# VISION_DISCOVERY_SERVICE_NAME=llm-openai
# VISION_DISCOVERY_ENDPOINT_NAME=chat_completions
# VISION_MODEL=Gemma 4 26B Heretic
# VISION_MAX_TOKENS=768
# VISION_TEMPERATURE=0.1
# VISION_DIRECT_IMAGE_LIMIT=2
# VISION_REQUEST_TIMEOUT_SECONDS=120

# -----------------------------------------------------------------------------
# Memory and redaction
# -----------------------------------------------------------------------------
# MEMORY_ENABLED=true
# MEMORY_RETENTION_HOURS=168
# MEMORY_CONSOLIDATION_PROVIDER=aifarm
# MEMORY_CONSOLIDATION_MODEL=Gemma 4 26B Heretic
# MEMORY_CONSOLIDATION_TIMEOUT_SECONDS=600
# MEMORY_DAILY_SCHEDULE=03:17
# MEMORY_DAILY_WINDOW_HOURS=24
# MEMORY_WORKER_CONCURRENCY=1
# MEMORY_MAX_MESSAGES_PER_RUN=200
# MEMORY_MAX_INPUT_TOKENS=10000
# MEMORY_TOKENIZER_MODEL=google/gemma-4-26B-A4B-it
# MEMORY_TOKENIZER_FILE=
# MEMORY_TOKEN_ESTIMATOR_URL=http://token-estimator:12600
# MEMORY_TOKEN_ESTIMATOR_TIMEOUT_SECONDS=2
# MEMORY_EMBEDDER_URL=http://embedder:12500
# MEMORY_EMBEDDING_MODEL=jinaai/jina-embeddings-v5-text-nano
# MEMORY_EMBEDDING_DIM=512
# MEMORY_AIFARM_SERVICE_NAME=llm-openai
# MEMORY_AIFARM_ENDPOINT_NAME=chat_completions
# MEMORY_AIFARM_MAX_OUTPUT_TOKENS=4096
# MEMORY_AIFARM_REQUEST_TIMEOUT_SECONDS=660
# MEMORY_AIFARM_POLL_INTERVAL_SECONDS=1
# MEMORY_AIFARM_TASK_TIMEOUT_SECONDS=720
# MEMORY_AIFARM_CAPACITY_WAIT_SECONDS=600
# MEMORY_AIFARM_CAPACITY_POLL_SECONDS=1
# MEMORY_AIFARM_TEMPERATURE=0.2
# MEMORY_AIFARM_ENABLE_THINKING=false
# MEMORY_REDACTION_ENABLED=true
# MEMORY_REDACTION_SERVICE_NAME=privacy-filter
# MEMORY_REDACTION_ENDPOINT_NAME=redact
# MEMORY_REDACTION_TIMEOUT_SECONDS=35
# MEMORY_REDACTION_TASK_TIMEOUT_SECONDS=60
# MEMORY_REDACTION_POLL_SECONDS=1
# MEMORY_REDACTION_CAPACITY_WAIT_SECONDS=30
# MEMORY_REDACTION_CAPACITY_POLL_SECONDS=1
# MEMORY_REDACTION_CATEGORIES=account_number,private_date,private_email,private_phone,private_url,secret

# -----------------------------------------------------------------------------
# Shield retrieval
# -----------------------------------------------------------------------------
# SHIELD_ENABLED=true
# SHIELD_EMBEDDER_URL=http://embedder:12500
# SHIELD_EMBEDDING_DIM=512
# SHIELD_MAX_MATCHES=3
# SHIELD_VECTOR_MIN_SCORE=0.48
# SHIELD_LEXICAL_MIN_SCORE=0.08
# SHIELD_QUERY_MAX_CHARS=4000
# SHIELD_RETRIEVAL_TIMEOUT_SECONDS=6
# SHIELD_HISTORY_TAIL_MESSAGES=0

# -----------------------------------------------------------------------------
# Smoke-script inputs
# -----------------------------------------------------------------------------
# OPENPLOTVA_SMOKE_CHAT_ID=
# OPENPLOTVA_SMOKE_USER_ID=
# OPENPLOTVA_SMOKE_PHOTO_FILE_ID=
# OPENPLOTVA_PROVIDER_SMOKE_GEMINI=auto
# OPENPLOTVA_PROVIDER_SMOKE_OPENROUTER=auto
# OPENPLOTVA_PROVIDER_SMOKE_SERPER=auto
# OPENPLOTVA_PROVIDER_SMOKE_TELEGRAM_MEMBERSHIP=auto
# OPENPLOTVA_LIVE_UPDATE_SMOKE_CASES=
# OPENPLOTVA_CLOSURE_LIVE_AUTO_OPTIONAL=1
# OPENPLOTVA_LIVE_UPDATE_SMOKE_TELEGRAM_MODE=
